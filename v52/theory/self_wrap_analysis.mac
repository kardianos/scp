print("3. BELTRAMI INCOMPATIBILITY (Analysis 3):")$
print("   Perfect self-trapping (curl(phi) = lambda phi) requires")$
print("   div(phi) = 0 and equal component magnitudes.")$
print("   The V(P) potential requires asymmetric components.")$
print("   CONCLUSION: Pure Beltrami self-trapping is INCOMPATIBLE")$
print("   with V(P) binding.  Only approximate Beltrami possible.")$
