print("   n = ceil(omega_L / omega_breath).")$
print("   For R=10 soliton with 10% breathing: P ~ 10^{-10}.")$
print("   PRACTICALLY ZERO on simulation timescales.")$
print("")$

print("7. SELF-WRAPPING COST IS SMALL (Analysis 7):")$
print("   The extra mass gap eta^2 = 0.25 on transverse modes is only")$
print("   11% of the bare m^2 = 2.25.  The strong V(P) binding (|mu|=41)")$
print("   easily overcomes this.  Self-wrapping HELPS stability by")$
print("   raising the minimum frequency for transverse radiation.")$
print("")$

