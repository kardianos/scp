(%i69) sgen:(u1^2+v1^2)*(u2^2+v2^2)*(u3^2+v3^2)
(%i70) Vt(s):=((mu/2)*s)/(1+kappa*s)
(%i71) chk("G8a_potential_charge_cancel",
           sum(uu[k]*diff(Vt(sgen),vv[k])-vv[k]*diff(Vt(sgen),uu[k]),k,1,3))
PASS G8a_potential_charge_cancel 
(%i72) DDreL(U,V):=makelist(
             lap(U[k])-g*divv(AA)*V[k]+(-2)*g*dotv(AA,gradv(V[k]))
                      +(-g^2)*dotv(AA,AA)*U[k],k,1,3)
(%i73) DDimL(U,V):=makelist(
             lap(V[k])+g*divv(AA)*U[k]+2*g*dotv(AA,gradv(U[k]))
                      +(-g^2)*dotv(AA,AA)*V[k],k,1,3)
(%i74) udd:DDreL(uu,vv)-m2*uu+eta*CcR(pp,qq,AA)
(%i75) vdd:DDimL(uu,vv)-m2*vv+eta*CcI(pp,qq,AA)
(%i76) pdd:DDreL(pp,qq)-mth2*pp+eta*CcR(uu,vv,AA)
(%i77) qdd:DDimL(pp,qq)-mth2*qq+eta*CcI(uu,vv,AA)
(%i78) rho:sum(uu[k]*diff(vv[k],t)-vv[k]*diff(uu[k],t)+pp[k]*diff(qq[k],t)
                                  +(-qq[k])*diff(pp[k],t),k,1,3)
(%i79) JJ:(-Jgrad(uu,vv))-Jgrad(pp,qq)+(-g)*(nrm(uu,vv)+nrm(pp,qq))*AA
                         +eta*(crossv(uu,qq)+crossv(pp,vv))
(%i80) rdot:diff(rho,t)
(%i81) eomsub:append(makelist('diff(uu[k],t,2) = udd[k],k,1,3),
                     makelist('diff(vv[k],t,2) = vdd[k],k,1,3),
                     makelist('diff(pp[k],t,2) = pdd[k],k,1,3),
                     makelist('diff(qq[k],t,2) = qdd[k],k,1,3))
(%i82) chk("G8_local_continuity",subst(eomsub,rdot)+divv(JJ))
PASS G8_local_continuity 
(%i83) LAdep:(-1/2)*K(uu,vv,AA)-(1/2)*K(pp,qq,AA)+Leta(uu,vv,pp,qq,AA)
