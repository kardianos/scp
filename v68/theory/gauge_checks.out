(%i61) L7e:subst(sub7u,Le)
(%i62) Fe_u1:subst(bak7u,diff(L7e,w0))-diff(subst(bak7u,diff(L7e,d1)),x)
                                      -diff(subst(bak7u,diff(L7e,d2)),y)
                                      -diff(subst(bak7u,diff(L7e,d3)),z)
