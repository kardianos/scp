   At core: (1125/2) * 0.02 * 0.16 = 1.8 code energy per voxel
   This is comparable to the existing potential V(P) ~ 1-5 per voxel.
   It would significantly modify the soliton structure. */

E_conf_core: gamma_needed_phi/2 * M_sq_core * phi_sq_core;
print("At gamma = ", float(gamma_needed_phi), ":")$
print("  V_conf at core ~ ", float(E_conf_core), " per voxel")$
print("  This is comparable to V(P) ~ 1-5 per voxel at the core.")$
print("  The mismatch potential would SIGNIFICANTLY deform the soliton.")$
print("")$

/* The coupled dispersion with mismatch potential:
   phi: omega^2 = k^2 + m^2 + gamma |M_0|^2 + ... (coupling terms)
   theta: omega^2 = k^2 + gamma |phi_0|^2 + ... (coupling terms)

   In the exterior (uniform background):
   m_phi_eff^2 = m^2 + gamma M_bg^2
   m_theta_eff^2 = gamma A_bg^2

   Coupled: (w - k^2 - m_phi_eff^2)(w - k^2 - m_theta_eff^2) = eta^2 k^2 */

print("Exterior coupled dispersion:")$
m2_phi_eff: m2_phi + gamma_needed_phi * M_sq_bg;
m2_theta_eff: gamma_needed_phi * phi_sq_exterior;
print("  m_phi_eff^2 = ", float(m2_phi_eff))$
print("  m_theta_eff^2 = ", float(m2_theta_eff))$
print("")$

eq7: (w - k^2 - m2_phi_eff) * (w - k^2 - m2_theta_eff) - eta_val^2 * k^2;
sol7: solve(eq7, w);
