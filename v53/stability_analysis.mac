print("  The phi mass gap m = 1.5 is BELOW the breathing frequency omega_b ~ 2-3.")$
print("  Any oscillation at omega > m can radiate into propagating phi waves.")$
print("  The breathing mode lives above this threshold -> it always radiates.")$
print("")$
print("The fundamental constraint:")$
print("  TOTAL STABILITY requires: min(m_phi_eff, m_theta_eff) > omega_b")$
print("                            everywhere in space (including vacuum).")$
print("")$

/* Compute the virial/breathing frequency relationship */
/* The breathing frequency is determined by V''(P) at the equilibrium.
   V(P) = (mu/2) P^2 / (1 + kappa P^2)
   V''(P) = mu (1 - 3 kappa P^2) / (1 + kappa P^2)^3
   At P = 0: V''(0) = mu = -41.345
   omega_b^2 ~ |V''(P_eq)| / M_eff where M_eff is the effective oscillation mass */

print("Breathing frequency analysis:")$
V(P) := mu_val/2 * P^2 / (1 + kappa_val * P^2)$
Vp(P) := ''(diff(V(P), P))$
Vpp(P) := ''(diff(V(P), P, 2))$
print("  V''(0) = ", float(subst(0, P, Vpp(P))))$
print("  V''(P) at P=0.05: ", float(subst(0.05, P, Vpp(P))))$
print("  V''(P) at P=0.08: ", float(subst(0.08, P, Vpp(P))))$
print("")$

/* At P=0: V''(0) = mu = -41.3. The local frequency omega_local ~ sqrt(|mu|) ~ 6.4.
   But the integrated breathing mode samples V'' over the soliton volume,
   and the effective mass is large. Typically omega_b ~ 2-3 from simulation. */

print("  omega_local(P=0) ~ sqrt(|V''(0)|) = sqrt(41.3) = ", float(sqrt(41.345)))$
print("  omega_b(simulation) ~ 2-3 (integrated over soliton, reduced by inertia)")$
print("")$

/* What parameters would give omega_b < m_phi = 1.5? */
/* Need: weaker potential (smaller |mu|) or larger soliton (more inertia).
   omega_b ~ sqrt(|mu|/M_eff). For omega_b < 1.5: |mu|/M_eff < 2.25. */

print("For omega_b < m_phi = 1.5:")$
print("  Need |mu| / M_eff < 2.25")$
print("  Current: |mu| = 41.3, omega_b ~ 2.5 -> M_eff ~ |mu|/omega_b^2 ~ 6.6")$
print("  Required: M_eff > 41.3/2.25 ~ 18.4 (2.8x larger soliton)")$
print("  OR: |mu| < 2.25 * 6.6 ~ 14.9 (reduce potential by 2.8x)")$
print("")$
print("  BUT: reducing |mu| weakens the binding that forms the soliton.")$
print("  And increasing the soliton size may not be compatible with stability.")$
print("  These are empirical questions requiring simulation.")$
print("")$

print("================================================================")$
print("TABLE: CONDITIONS FOR EACH MODIFICATION TO ACHIEVE TOTAL STABILITY")$
print("================================================================")$
print("")$

