print("  Linearized: - gamma |phi_0|^2 delta_theta")$
print("  Effective theta mass: m_th_eff^2(x) = gamma |phi_0(x)|^2")$
print("")$

/* phi amplitude at soliton core: |phi_0| ~ A_bg + A_soliton ~ 0.1 + 0.3 = 0.4 */
phi_sq_core: 0.16$
phi_sq_exterior: 0.01$ /* just the background A_bg^2 */

print("  Core: m_th_eff^2 = gamma * ", phi_sq_core)$
print("  Exterior: m_th_eff^2 = gamma * ", phi_sq_exterior, " (from background A_bg=0.1)")$
print("")$

/* AH: the background carrier wave A_bg means |phi|^2 is NONZERO even outside!
