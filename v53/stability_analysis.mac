print("")$

/* Actually, let's be precise. V_conf = (gamma/2) |M|^2 |phi|^2
   where M = curl(phi)/2 - theta.

   Variation with respect to phi_a:
   dV/dphi_a = gamma |M|^2 phi_a + (gamma/2) |phi|^2 d|M|^2/dphi_a

   But d|M|^2/dphi_a involves d/dphi_a of M_b M_b where M_b = (curl phi)_b/2 - theta_b.
   d M_b/d phi_a = (1/2) d(curl phi)_b / d phi_a -- this involves derivatives of phi_a,
   so it's really a variational derivative, not a partial derivative.

   Let me simplify by considering the leading term: gamma |M_0|^2 phi
   where M_0 is the background mismatch (frozen). */

print("Simplification: treat M = M_0(x) as frozen background mismatch.")$
print("  Then the phi fluctuation sees:")$
print("  d^2 delta_phi/dt^2 = laplacian(delta_phi) - (m^2 + gamma |M_0|^2) delta_phi + ...")$
print("")$
print("  Effective mass: m_eff^2(x) = m^2 + gamma |M_0(x)|^2")$
print("")$

/* The mismatch profile: M = curl(phi)/2 - theta.
   In equilibrium, theta ~ (eta/m_th^2) curl(phi) from the theta equation.
   With m_th = 0: theta adjusts to make M small!
   But not exactly zero — the dynamics prevent perfect matching.

   From V50 data: |M| is largest at the soliton core.
   |M_0|^2 ~ (curl(phi)/2)^2 at core since theta lags curl(phi)/2.
   Typical: |curl(phi)| ~ 0.3 at core, so |M|^2 ~ (0.15)^2 ~ 0.02 */

M_sq_core: 0.02$
M_sq_exterior: 0.0$

print("Mismatch profile:")$
print("  Core: |M_0|^2 ~ ", M_sq_core, " (curl(phi)/2 and theta don't match perfectly)")$
print("  Exterior: |M_0|^2 -> 0 (both curl(phi) and theta vanish)")$
print("")$

print("Effective mass profile:")$
print("  Core: m_eff^2 = 2.25 + gamma * ", M_sq_core, " = 2.25 + ", M_sq_core, " gamma")$
print("  Exterior: m_eff^2 = 2.25 + 0 = 2.25 (unchanged!)")$
print("")$

/* SAME PROBLEM as Modification 3: the mass is enhanced INSIDE but unchanged OUTSIDE.
   The exterior mass gap is still m = 1.5 < omega_b. */

