print("KEY INSIGHT: The background carrier wave (A_bg = 0.1) gives")$
print("  |phi|^2 = A_bg^2 = 0.01 EVERYWHERE (including vacuum).")$
print("  This creates a UNIFORM theta mass gap:")$
print("  m_th_uniform^2 = gamma * A_bg^2 = 0.01 * gamma")$
print("")$

/* For theta gap to exceed omega_b: */
print("For theta confinement: m_th_uniform > omega_b ~ 3")$
print("  gamma * 0.01 > 9")$
gamma_needed_theta: 9 / phi_sq_exterior;
