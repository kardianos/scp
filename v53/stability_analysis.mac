print("================================================================")$
print("MODIFICATION 6: TOPOLOGICAL MASS (CHERN-SIMONS-LIKE)")$
print("================================================================")$
print("")$
print("Modified theta equation:")$
print("  d^2 theta/dt^2 = laplacian(theta) + eta curl(phi) + mu_CS theta x d(theta)/dt")$
print("  where (theta x d(theta)/dt)_a = epsilon_abc theta_b d(theta_c)/dt")$
print("")$
print("Alternatively, the standard Chern-Simons mass in 3D gauge theory:")$
print("  epsilon^{mu nu rho} A_nu F_{rho sigma} gives mass mu_CS to the gauge field.")$
print("  Adapted to our scalar-vector system:")$
print("  Add: mu_CS epsilon_abc theta_b (curl theta)_c  to the theta_a equation")$
print("")$

/* In 3D, a Chern-Simons mass term for a vector field theta is:
   L_CS = (mu_CS/2) epsilon^{ijk} theta_i d_j theta_k = (mu_CS/2) theta . curl(theta)
   The EL equation gives: mu_CS curl(theta) as a first-order term.

   For a plane wave theta = theta_0 e^{i(k.x - omega t)}:
   curl(theta) = ik x theta_0 e^{i(k.x - omega t)}
   The CS term adds mu_CS (ik x theta_0) to the equation of motion. */

print("Chern-Simons mass for vector field:")$
print("  L_CS = (mu_CS/2) theta . curl(theta)")$
print("  EOM addition: + mu_CS curl(theta)  (first order in spatial derivatives)")$
print("")$

/* The theta dispersion with CS mass:
   For a plane wave propagating in z with circular polarization:
   theta = (xhat +/- i yhat) theta_0 e^{i(kz - omega t)}
   curl(theta) = +/- k theta (for circular polarization)

   -omega^2 theta = -k^2 theta + mu_CS (+/- k) theta
   omega^2 = k^2 -/+ mu_CS k

   For + helicity: omega^2 = k^2 - mu_CS k
   For - helicity: omega^2 = k^2 + mu_CS k */

print("Theta dispersion with CS mass (circular polarization basis):")$
print("  + helicity: omega^2 = k^2 - mu_CS k")$
print("  - helicity: omega^2 = k^2 + mu_CS k")$
print("")$

/* The + helicity has omega^2 = k^2 - mu_CS k = k(k - mu_CS).
   This is NEGATIVE for 0 < k < mu_CS! TACHYONIC INSTABILITY. */

print("CRITICAL: + helicity has omega^2 = k(k - mu_CS)")$
print("  For 0 < k < mu_CS: omega^2 < 0  ->  TACHYONIC INSTABILITY!")$
print("  The theory is ILL-DEFINED with this sign.")$
print("")$

/* The - helicity: omega^2 = k^2 + mu_CS k = k(k + mu_CS) >= 0 always.
   But at k=0: omega^2 = 0. STILL GAPLESS. */

print("  - helicity: omega^2 = k(k + mu_CS) >= 0, BUT omega(k=0) = 0")$
print("  STILL GAPLESS for the - helicity mode.")$
print("")$

/* What about the topological mass in 2+1D? In 2+1D, CS gives a genuine
   mass: omega^2 = k^2 + mu_CS^2. But in 3+1D, the CS term is first-order
   in k, not zeroth-order, so it gives a linear shift, not a mass gap. */

print("The Chern-Simons mechanism in 3+1D:")$
print("  In 2+1D: L_CS = mu_CS epsilon^{mu nu rho} A_mu d_nu A_rho")$
print("    -> omega^2 = k^2 + mu_CS^2 (genuine mass gap!)")$
print("")$
print("  In 3+1D: L_CS = mu_CS theta . curl(theta)")$
print("    -> omega^2 = k^2 +/- mu_CS k (NO gap, just helicity splitting)")$
print("    This is because in 3+1D, the CS term has one spatial derivative")$
print("    (curl), giving linear-in-k correction, not constant.")$
print("")$

/* Alternative: use a Proca-like topological term?
   theta x d(theta)/dt is a zeroth-order-in-k term:
   For plane wave: theta x (-i omega theta) = -i omega (theta x theta) = 0
   because theta x theta = 0 for any vector with itself! */

print("Alternative: theta x d(theta)/dt term")$
print("  For a single plane wave: theta x theta = 0 identically.")$
print("  This term VANISHES for linear waves. No effect on dispersion.")$
print("")$

/* What about a B x F term (like magnetic Chern-Simons)?
   Add: mu_CS theta_a x partial_t theta_a to the EOM.
   No, this is theta . d(theta)/dt which is a total time derivative
   and doesn't affect the EOM. */

/* The true topological mass in 3+1D requires a 2-form (Kalb-Ramond):
   B_{mu nu} with L = epsilon^{mu nu rho sigma} B_{mu nu} F_{rho sigma}
   But theta is a 1-form (vector), not a 2-form. */

print("In 3+1D, a TRUE topological mass requires a 2-form field (Kalb-Ramond),")$
print("  not a 1-form (vector). Our theta is a vector field, so the genuine")$
print("  topological mass mechanism is NOT available.")$
print("")$

/* Last resort: massive Chern-Simons: add both mu_CS curl(theta) AND m_th^2 theta.
   omega^2 = k^2 + m_th^2 +/- mu_CS k
   For - helicity: gap at omega_min^2 = m_th^2 (at k=0). Gapped.
   For + helicity: minimum at k = mu_CS/2, omega_min^2 = m_th^2 - mu_CS^2/4
   Need m_th > mu_CS/2 for stability. */

print("Combined: CS + mass term")$
print("  omega^2 = k^2 + m_th^2 +/- mu_CS k")$
eq6_plus: k^2 + mt^2 - muCS*k;
eq6_minus: k^2 + mt^2 + muCS*k;
print("  + helicity: omega^2 = k^2 + m_th^2 - mu_CS k")$
k_min6: muCS/2;
omega_min6: mt^2 - muCS^2/4;
print("    minimum at k = mu_CS/2: omega_min^2 = m_th^2 - mu_CS^2/4")$
print("    stable if m_th > mu_CS/2")$
print("  - helicity: omega^2 = k^2 + m_th^2 + mu_CS k, minimum at k=0: omega^2 = m_th^2")$
print("")$
print("  This REQUIRES a mass term m_th anyway! The CS term alone does nothing in 3+1D.")$
print("  We're back to Modification 1 (massive theta) plus a helicity splitting.")$
print("")$

print("--- MODIFICATION 6 VERDICT ---")$
print("  Term: mu_CS theta . curl(theta) (Chern-Simons)")$
print("  Dispersion: omega^2 = k^2 +/- mu_CS k (helicity-dependent)")$
print("  Problem: in 3+1D, CS gives k-linear shift, NOT mass gap")$
print("  One helicity becomes tachyonic for k < mu_CS")$
print("  Total stability: NO (without additional mass term)")$
print("  Dealbreaker: topological mass requires 2+1D, not 3+1D.")$
print("    In 3+1D, the CS term splits helicities but creates no gap.")$
