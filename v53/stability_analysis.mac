print("  omega_-^2 = ", gap7_minus, " -> omega_- = ", float(sqrt(abs(gap7_minus))))$
print("  omega_+^2 = ", gap7_plus, " -> omega_+ = ", float(sqrt(abs(gap7_plus))))$
print("")$

/* Check if the lower gap exceeds omega_b */
print("Lower gap omega_- = ", float(sqrt(abs(gap7_minus))))$
print("Breathing freq omega_b ~ 2-3")$
if gap7_minus > omega_b_high^2 then
  print("  omega_- > omega_b(high): YES, total confinement achieved!")
else if gap7_minus > omega_b_low^2 then
  print("  omega_- > omega_b(low) but < omega_b(high): MARGINAL")
else
