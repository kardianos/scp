/* stability_analysis.mac — 7 modifications for total soliton stability
 *
 * Current V50/C4 Cosserat equations:
 *   d^2 phi/dt^2 = laplacian(phi) - m^2 phi - V'(P) dP/dphi + eta curl(theta)
 *   d^2 theta/dt^2 = laplacian(theta) - m_th^2 theta + eta curl(phi)
 *
 * Parameters: m^2=2.25 (m=1.5), mu=-41.345, kappa=50, eta=0.5, m_th=0.
 *
 * Radiation problem:
 *   - phi has mass gap omega=m=1.5; harmonics above m radiate
 *   - theta is massless; ALL oscillations radiate
 *   - breathing frequency omega_b ~ 2.0-3.0 (from V43/V50 numerics)
 *
 * We analyze 7 modifications that could achieve total confinement.
 *
 * Run: maxima --batch=v53/stability_analysis.mac
 */

/* ================================================================
   SETUP AND CONVENTIONS
   ================================================================ */

/* Physical parameters */
m_phi: 3/2$           /* phi mass = 1.5 */
m2_phi: m_phi^2$      /* m^2 = 2.25 */
eta_val: 1/2$         /* curl coupling */
mu_val: -41.345$      /* potential strength */
kappa_val: 50$        /* potential saturation */
omega_b_low: 2.0$     /* estimated breathing freq lower bound */
omega_b_high: 3.0$    /* estimated breathing freq upper bound */

/* The base dispersion (uncoupled, for reference):
   phi: omega^2 = k^2 + m^2   (gapped, gap at omega=m=1.5)
   theta: omega^2 = k^2       (gapless, radiates at all frequencies)

   Coupled (from v50/em_wave/dispersion.mac):
   (omega^2 - k^2 - m^2)(omega^2 - k^2) = eta^2 k^2
   Two branches: "matter" (gap at ~m) and "polariton" (gapless)
*/

print("================================================================")$
print("SOLITON STABILITY ANALYSIS — 7 MODIFICATIONS")$
print("V50/C4 Cosserat Equations")$
print("================================================================")$
print("")$
print("Base parameters: m_phi=1.5, eta=0.5, m_theta=0")$
print("Breathing frequency: omega_b ~ 2.0 to 3.0")$
print("Problem: theta is massless -> all theta oscillations radiate")$
print("         phi harmonics above m=1.5 also radiate")$
print("")$

/* ================================================================
   MODIFICATION 1: Massive theta (m_theta > 0)
   ================================================================ */

print("================================================================")$
print("MODIFICATION 1: MASSIVE THETA (m_theta > 0)")$
print("================================================================")$
print("")$
print("Modified theta equation:")$
print("  d^2 theta/dt^2 = laplacian(theta) - m_th^2 theta + eta curl(phi)")$
print("")$

/* Coupled dispersion with massive theta:
   (omega^2 - k^2 - m_phi^2)(omega^2 - k^2 - m_th^2) = eta^2 k^2 */

declare([w, k, m, mt, eta], real)$
assume(w > 0, k >= 0, m > 0, mt > 0, eta > 0)$

eq1: (w - k^2 - m^2) * (w - k^2 - mt^2) - eta^2 * k^2;

print("Dispersion equation (w = omega^2):")$
print(expand(eq1), " = 0")$
print("")$

sol1: solve(eq1, w);
w1_minus: rhs(sol1[1]);
w1_plus: rhs(sol1[2]);

print("Two branches:")$
print("  w_- = ", w1_minus)$
print("  w_+ = ", w1_plus)$
print("")$

/* At k=0: the gaps */
gap_minus: subst(0, k, w1_minus);
gap_plus: subst(0, k, w1_plus);

print("At k=0 (mass gaps):")$
print("  omega_-^2 = ", gap_minus)$
print("  omega_+^2 = ", gap_plus)$
print("")$

/* For total stability: BOTH gaps must exceed omega_b.
   The lower branch gap at k=0 is min(m^2, mt^2).
   For phi-theta coupling, the lower branch becomes:
     omega_min^2 = min(m^2, mt^2)  (at leading order when eta is small)
   More precisely, the lower branch at k=0 is the smaller of m^2 and mt^2. */

print("The lower branch gap at k=0 = min(m_phi^2, m_theta^2)")$
print("For total confinement: min(m^2, m_th^2) > omega_b^2")$
print("")$

/* Condition: both gaps above breathing frequency */
/* If mt < m, the lower gap is mt^2. Need mt > omega_b. */
/* If mt > m, the lower gap is m^2 = 2.25. Need m > omega_b, i.e. omega_b < 1.5.
   But omega_b ~ 2-3 > 1.5, so this fails. We ALWAYS need both to exceed omega_b. */

print("Critical condition:")$
print("  m_theta > omega_b  AND  m_phi > omega_b")$
print("")$
print("  m_phi = 1.5 and omega_b ~ 2.0-3.0")$
print("  PROBLEM: m_phi < omega_b ! The phi gap is TOO LOW.")$
print("")$
print("  Even with massive theta, the phi branch still radiates")$
print("  because the breathing frequency exceeds the phi mass gap.")$
print("")$

/* Check: does the coupling modify the gap? */
/* At k=0, eta^2*k^2 = 0, so the gaps are exactly m^2 and mt^2. No shift. */
print("Note: at k=0, the eta coupling vanishes (eta^2 k^2 = 0),")$
print("so the gaps are EXACTLY m_phi^2 and m_theta^2. No renormalization.")$
print("")$

/* What if mt is very large? Then the theta branch is frozen,
   and the breathing frequency might drop below m. */
print("Could m_theta shift the breathing frequency below m_phi?")$
print("  The breathing freq depends on the NONLINEAR potential V(P),")$
print("  not on the linear mass gap. A massive theta would reduce the")$
print("  curl energy exchange, potentially reducing breathing amplitude,")$
print("  but the frequency is set by V''(P_0) at the equilibrium value.")$
print("")$
print("  V''(P) at P=P_0 determines omega_b ~ sqrt(V''(P_0)/rho)")$
print("  This is independent of m_theta to leading order.")$
print("")$

/* Numerical check: what m_theta is needed if omega_b could be brought below m? */
print("If we could tune omega_b < 1.5 AND m_theta > omega_b:")$
print("  Need: m_theta > omega_b AND omega_b < 1.5")$
print("  Minimum m_theta = omega_b")$
print("  With omega_b = 1.4 (hypothetical): m_theta > 1.4 suffices")$
print("")$

/* But the actual omega_b is 2-3, so: */
print("With actual omega_b ~ 2-3: m_phi = 1.5 < 2 = omega_b")$
print("Phi radiation CANNOT be stopped by making theta massive alone.")$
print("")$

/* Would increasing m_phi help? */
print("Alternative: increase m_phi to m_phi > omega_b.")$
print("  Need m_phi > omega_b ~ 2-3, so m^2 > 4-9.")$
print("  Currently m^2 = 2.25. Would need m^2 > 4 (m > 2).")$
print("  But m controls the soliton SIZE: R ~ 1/m.")$
print("  Doubling m halves the soliton, changes all physics.")$
print("")$

/* Does killing the exchange kill the soliton? */
print("Does massive theta kill the soliton?")$
print("  The phi-theta exchange sustains breathing via curl coupling.")$
print("  With m_theta >> omega_b, theta responds adiabatically (no oscillation).")$
print("  The curl force becomes purely restorative, not oscillatory.")$
print("  The soliton can still exist (it's a V(P) bound state),")$
print("  but the breathing mode loses its theta-mediated energy channel.")$
print("  HOWEVER: the soliton was found to REQUIRE breathing to survive")$
print("  in V50 simulations. No breathing -> no stability -> soliton dies.")$
print("")$

print("--- MODIFICATION 1 VERDICT ---")$
print("  Dispersion: omega^2 = k^2 + min(m^2, m_th^2) at k=0")$
print("  Stability condition: min(m, m_th) > omega_b")$
print("  FAILS: m_phi=1.5 < omega_b~2-3, so phi branch always radiates")$
print("  Total stability: NO (unless m_phi is also increased)")$
print("  Dealbreaker: breathing freq exceeds phi mass gap")$
print("================================================================")$
print("")$


/* ================================================================
   MODIFICATION 2: Nonlinear theta self-interaction
   ================================================================ */

print("================================================================")$
print("MODIFICATION 2: NONLINEAR THETA SELF-INTERACTION")$
print("================================================================")$
print("")$
print("Modified theta equation:")$
print("  d^2 theta/dt^2 = laplacian(theta) + eta curl(phi) - lambda_th |theta|^2 theta")$
print("  (from V_theta = (lambda_th/4)|theta|^4)")$
print("")$

/* Case A: Simple quartic |theta|^4 around background theta_0 */
/* Linearize: theta = theta_0(x) + delta_theta(x,t) e^{i omega t}
   Effective mass: m_th_eff^2 = 3 lambda_th theta_0^2 (for radial mode)
                   m_th_eff^2 = lambda_th theta_0^2 (for Goldstone modes) */

print("Case A: V_theta = (lambda_th/4)|theta|^4")$
print("  Linearize around background theta_0(x):")$
print("  Effective mass squared: m_th_eff^2(x) = 3 lambda_th theta_0(x)^2")$
print("  (radial mode, factor 3 from 3|theta_0|^2 delta_theta perturbation)")$
print("")$

/* Inside soliton: theta_0 ~ eta/m^2 * curl(phi_0) from equilibrium.
   Typical theta amplitude in soliton core from V50: theta_rms ~ 0.1 */
theta_core: 0.1$

print("Inside soliton core: theta_0 ~ ", theta_core)$
print("  m_th_eff^2 = 3 lambda_th * ", theta_core^2)$
print("  For m_th_eff > omega_b ~ 3: need 3 lambda_th * 0.01 > 9")$
lambda_th_needed_A: 9 / (3 * theta_core^2);
print("  lambda_th > ", float(lambda_th_needed_A))$
print("")$

/* PROBLEM: outside the soliton, theta_0 -> 0, so m_th_eff -> 0.
   Theta waves are UNCONFINED in the exterior. */
print("PROBLEM: Outside soliton, theta_0 -> 0, so m_th_eff -> 0")$
print("  Theta waves are unconfined in the vacuum. This DOES NOT WORK.")$
print("")$

/* Case B: Mexican hat V_theta = -mu_th |theta|^2 + lambda_th |theta|^4 */
print("Case B: Mexican hat V_theta = -mu_th^2 |theta|^2 + (lambda_th/4)|theta|^4")$
print("  Vacuum: theta_0 = sqrt(mu_th^2/lambda_th) everywhere (condensate)")$
print("  Fluctuation mass: m_th_eff^2 = 2 mu_th^2 (radial Higgs mode)")$
print("  Goldstone modes: 2 massless modes (broken SO(3) -> SO(2))")$
print("")$

/* The radial (Higgs) mode has a gap. But there are 2 Goldstone modes. */
print("  Gap analysis:")$
print("  - 1 radial mode: gapped at m_Higgs = sqrt(2) mu_th")$
print("  - 2 Goldstone modes: MASSLESS (broken rotational symmetry)")$
print("")$
print("  The Goldstone modes radiate just like the original massless theta.")$
print("  We've traded 3 massless modes for 2 massless + 1 massive.")$
print("  Net: WORSE (new vacuum structure, still massless radiation).")$
print("")$

/* Case C: Explicit mass + quartic */
print("Case C: V_theta = (m_th^2/2)|theta|^2 + (lambda_th/4)|theta|^4")$
print("  All 3 theta modes get gap m_th from the mass term.")$
print("  The quartic adds amplitude-dependent correction.")$
print("  Effective gap: omega_min^2 = m_th^2 + 3 lambda_th theta_0^2")$
print("  Inside soliton: larger gap (good — more confinement)")$
print("  Outside: gap = m_th (uniform, nonzero)")$
print("")$
print("  This reduces to Modification 1 + a perturbative correction.")$
print("  The quartic helps inside but the LIMITING factor is the")$
print("  exterior gap, which is just m_th.")$
print("")$
print("  Same conclusion as Mod 1: need m_th > omega_b AND m_phi > omega_b.")$
print("")$

print("--- MODIFICATION 2 VERDICT ---")$
print("  Case A (quartic only): Traps inside, leaks outside. FAILS.")$
print("  Case B (Mexican hat): Creates Goldstone modes. WORSE.")$
print("  Case C (mass + quartic): Reduces to Mod 1. Same problem.")$
print("  Stability condition: still need m_phi > omega_b (unachieved)")$
print("  Total stability: NO")$
print("  Dealbreaker: exterior vacuum always allows propagation at omega < m_phi")$
print("================================================================")$
print("")$


/* ================================================================
   MODIFICATION 3: Gradient-dependent mass (Skyrme L4 term)
   ================================================================ */

print("================================================================")$
print("MODIFICATION 3: GRADIENT-DEPENDENT MASS (SKYRME L4)")$
print("================================================================")$
print("")$
print("Modified phi equation (add Skyrme quartic gradient):")$
print("  L4 = (c4/2) |grad(phi)|^2 |grad(phi)|^2  (simplified scalar form)")$
print("  m_eff^2(x) = m^2 + c4 |grad(phi_0)|^2")$
print("")$

/* The effective mass inside the soliton:
   |grad(phi)|^2 at the soliton core ~ (A/R)^2 where A ~ amplitude, R ~ size */
/* From V50 data: typical |grad(phi)| ~ 0.5 at core, so |grad(phi)|^2 ~ 0.25 */
grad_phi_sq_core: 0.25$

print("Inside soliton core: |grad(phi_0)|^2 ~ ", grad_phi_sq_core)$
print("  m_eff^2 = 2.25 + c4 * 0.25")$
print("  For m_eff > omega_b ~ 3: need m_eff^2 > 9")$
c4_needed: (9 - m2_phi) / grad_phi_sq_core;
print("  c4 > (9 - 2.25)/0.25 = ", float(c4_needed))$
print("")$

/* But this RAISES the mass inside the soliton, not outside.
   Outside: |grad(phi)|^2 -> 0, so m_eff -> m_phi = 1.5.
   The exterior mass gap is still m_phi. */

print("CRITICAL: The gradient-dependent mass is LARGER inside the soliton")$
print("  and SMALLER (= m_phi) outside. This is BACKWARDS for confinement!")$
print("")$
print("  Waves generated inside (at high m_eff) propagate outward into")$
print("  a region of LOWER effective mass. They are NOT reflected back.")$
print("  Instead, the interior acts like a high-mass 'source' region")$
print("  and the exterior is a low-mass 'propagation' region.")$
print("")$

/* Could it still help? The inside-generated waves have omega set by the
   breathing mode. If m_eff_inside > omega_b, the breathing can't generate
   propagating modes INSIDE. But then how does it breathe at all? */

print("Subtlety: If m_eff(core) > omega_b, the breathing mode itself")$
print("  cannot exist as a propagating wave inside the core.")$
print("  This means the breathing becomes EVANESCENT inside the soliton.")$
print("  The soliton cannot sustain internal oscillations above m_eff(core).")$
print("")$
print("  But the soliton needs breathing to survive! (V50 result)")$
print("  A gradient mass that kills internal oscillation kills the soliton.")$
print("")$

/* Linearized dispersion for a wave in the soliton background:
   omega^2 = k^2 + m^2 + c4 |grad(phi_0)|^2
   This is a position-dependent mass. The WKB condition for trapping:
   omega^2 < m_eff^2(x) everywhere -> wave is evanescent everywhere.
   But m_eff decreases outward, so there's always a classical turning point. */

print("WKB analysis:")$
print("  Propagation when omega^2 > k^2 + m_eff^2(x)")$
print("  Since m_eff^2 DECREASES outward (from m^2+c4*|grad|^2 to m^2),")$
print("  any wave with omega > m_phi CAN propagate in the exterior.")$
print("  There is NO trapping — the mass profile is a POTENTIAL HILL,")$
print("  not a potential well.")$
print("")$

/* Dispersion relation in uniform background with gradient mass */
print("Uniform-background dispersion (for reference):")$
print("  omega^2 = k^2 + m^2 + c4 G^2  (G^2 = |grad phi_0|^2 = const)")$
print("  Gap: omega_min = sqrt(m^2 + c4 G^2)")$
print("  This is just a shifted mass. No qualitative change.")$
print("")$

print("--- MODIFICATION 3 VERDICT ---")$
print("  Effective mass: m_eff^2 = m^2 + c4 |grad(phi)|^2")$
print("  Dispersion: omega^2 = k^2 + m_eff^2(x) (position-dependent)")$
print("  Problem: m_eff is HIGHEST at center, LOWEST at exterior")$
print("  This creates a potential HILL, not a well. No trapping.")$
print("  Total stability: NO")$
print("  Dealbreaker: gradient mass is backwards — high inside, low outside")$
print("================================================================")$
print("")$


/* ================================================================
   MODIFICATION 4: Cross-gradient coupling
   ================================================================ */

print("================================================================")$
print("MODIFICATION 4: CROSS-GRADIENT COUPLING |grad(phi)|^2 |grad(theta)|^2")$
print("================================================================")$
print("")$
print("Added Lagrangian term:")$
print("  L_cross = (beta/2) |grad(phi)|^2 |grad(theta)|^2")$
print("")$
print("Theta equation (from EL variation):")$
print("  d^2 theta/dt^2 = laplacian(theta) + eta curl(phi)")$
print("                   + beta div(|grad(phi)|^2 grad(theta))")$
print("")$

/* Linearize: theta = theta_0 + delta_theta e^{i(k.x - omega t)}
   In background phi_0(x), the theta fluctuation sees:
   omega^2 delta_theta = -k^2 delta_theta + beta |grad(phi_0)|^2 k^2 delta_theta
   i.e., omega^2 = k^2 (1 + beta |grad(phi_0)|^2)
   at leading order (ignoring the curl coupling for the dispersion). */

print("Linearized theta dispersion in soliton background:")$
print("  omega^2 = k^2 (1 + beta |grad(phi_0)|^2)")$
print("  (ignoring phi-theta coupling for clarity)")$
print("")$

/* This INCREASES the propagation speed inside the soliton.
   The effective speed: c_eff^2 = 1 + beta G^2 > 1 where G^2 = |grad phi_0|^2.
   Faster propagation is the OPPOSITE of trapping. */

print("Effective propagation speed: c_eff^2 = 1 + beta |grad(phi_0)|^2")$
print("  Inside soliton: c_eff > 1 (FASTER)")$
print("  Outside: c_eff = 1")$
print("")$
print("  This means waves propagate FASTER inside, not slower.")$
print("  Faster interior = waves ESCAPE more easily. WRONG direction.")$
print("")$

/* What about negative beta? */
print("With beta < 0:")$
print("  c_eff^2 = 1 - |beta| |grad(phi_0)|^2")$
print("  Inside: c_eff < 1 (slower)")$
print("  If |beta| |grad(phi_0)|^2 > 1: c_eff^2 < 0 (IMAGINARY!)")$
print("  This is a gradient instability — theta becomes tachyonic.")$
print("  The field theory is ill-defined for large negative beta.")$
print("")$

/* Could negative beta create an effective mass? */
/* omega^2 = k^2 (1 - |beta| G^2). If 1 - |beta|G^2 < 0, then omega^2 < 0
   for all k. This is an instability, not a gap. */

print("Negative beta analysis:")$
print("  omega^2 = k^2 (1 - |beta| G^2)")$
print("  When |beta| G^2 > 1: omega^2 < 0 for all k -> TACHYONIC INSTABILITY")$
print("  When |beta| G^2 < 1: gapless dispersion with reduced speed")$
print("  In NEITHER case is there a mass gap. Still gapless.")$
print("")$

/* Full coupled dispersion with cross-gradient */
/* phi: omega^2 = k^2 + m^2 + eta k delta_theta (curl)
   theta: omega^2 = k^2(1 + beta G^2) + eta k delta_phi (curl)
   Determinant: (omega^2 - k^2 - m^2)(omega^2 - k^2(1+beta G^2)) = eta^2 k^2 */

print("Full coupled dispersion:")$
eq4: (w - k^2 - m^2) * (w - k^2*(1 + beta*G2)) - eta^2*k^2;
print(expand(eq4), " = 0")$
print("")$

/* At k=0: w*(w - m^2) = 0, gaps are 0 and m^2. Still gapless lower branch. */
gap4_k0: subst(0, k, eq4);
print("At k=0: ", expand(gap4_k0), " = 0")$
print("  Solutions: w = 0 and w = m^2")$
print("  LOWER BRANCH IS STILL GAPLESS.")$
print("")$

print("--- MODIFICATION 4 VERDICT ---")$
print("  Term: (beta/2)|grad(phi)|^2 |grad(theta)|^2")$
print("  Dispersion: omega^2 = k^2(1+beta G^2) (theta branch)")$
print("  Stability condition: NONE — no mass gap created")$
print("  Total stability: NO")$
print("  Dealbreaker: cross-gradient coupling changes wave SPEED, not gap.")$
print("    It cannot create a mass gap. The lower branch is always gapless at k=0.")$
print("================================================================")$
print("")$


/* ================================================================
   MODIFICATION 5: Higher-order curl coupling (curl^2 feedback)
   ================================================================ */

print("================================================================")$
print("MODIFICATION 5: HIGHER-ORDER CURL (curl^2 FEEDBACK)")$
print("================================================================")$
print("")$
print("Modified phi equation:")$
print("  d^2 phi/dt^2 = laplacian(phi) - m^2 phi - V'(P) dP/dphi")$
print("                 + eta curl(theta) + alpha2 curl(curl(theta))")$
print("")$
print("Modified theta equation:")$
print("  d^2 theta/dt^2 = laplacian(theta) + eta curl(phi) + alpha2 curl(curl(phi))")$
print("")$

/* Note: curl(curl(F)) = grad(div(F)) - laplacian(F).
   For a transverse wave (div=0): curl(curl(F)) = -laplacian(F).
   So curl^2 on a transverse mode acts like -k^2. */

print("Key identity: curl(curl(F)) = grad(div(F)) - laplacian(F)")$
print("  For transverse waves (div F = 0): curl(curl(F)) = -laplacian(F)")$
print("  In Fourier: curl(curl) -> k^2 (NOT k^4 !)")$
print("")$

/* Linearized dispersion for transverse plane wave:
   phi: omega^2 = k^2 + m^2 + eta*k + alpha2*k^2 (from curl + curl^2 of theta)
   theta: omega^2 = k^2 + eta*k + alpha2*k^2

   Wait, let me be more careful. For a transverse wave in z-direction:
   phi_x, theta_y coupled. curl(theta) on phi_x gives +ik theta_y.
   curl(curl(theta)) on phi_x gives -k^2 theta_y (for transverse mode).

   So the coupled system becomes:
   (omega^2 - k^2 - m^2) phi = eta (ik) theta + alpha2 (-k^2) theta
                              = (i eta k - alpha2 k^2) theta
   (omega^2 - k^2) theta = eta (ik) phi + alpha2 (-k^2) phi
                          = (i eta k - alpha2 k^2) phi

   For the determinant, the coupling enters as |C(k)|^2 where
   C(k) = i eta k - alpha2 k^2.
   |C|^2 = eta^2 k^2 + alpha2^2 k^4  (cross term vanishes: real * imag)

   Actually: for the REAL dispersion (not complex), we should work with
   the magnitude. The curl coupling gives eta*k (magnitude) and the
   curl^2 gives alpha2*k^2. But they have different phases (curl is
   antisymmetric, curl^2 is symmetric). Let me redo this carefully.
*/

print("Careful linearization:")$
print("  Transverse wave propagating in z, phi_x and theta_y coupled.")$
print("  curl(theta e^{ikz}) projected onto x-component: ik theta_y")$
print("  curl(curl(theta e^{ikz})) projected onto x: +k^2 theta_y")$
print("    (for transverse mode; curl curl = -laplacian when div=0)")$
print("")$

/* The sign matters. curl(curl(theta)) for a plane wave:
   theta = theta_y yhat e^{ikz}
   curl(theta) = ik theta_y xhat e^{ikz}  (xhat component of curl)
   curl(curl(theta)) = curl(ik theta_y xhat e^{ikz})
     z-component of curl: d/dx(ik theta_y e^{ikz}) - d/dy(0) = 0 (theta_y const)
     y-component: d/dz(0) - d/dx(?) = ...

   Actually, for F = f yhat e^{ikz}:
   curl(F) = -ik f xhat e^{ikz}
   curl(curl(F)) = curl(-ik f xhat e^{ikz})
     = -(ik)(-ik) f yhat e^{ikz} = -k^2 f yhat e^{ikz}

   So curl(curl(theta))_on_theta = -k^2 theta.
   And curl(curl(theta))_projected_onto_phi_x equation:
     alpha2 * curl(curl(theta)) in the phi_x equation...

   We need to be more careful about the coupling structure.
   The original: eta * curl(theta)_x = eta * (-ik theta_y)
   The new: alpha2 * curl(curl(theta))_x = alpha2 * (-ik)(-ik theta_y) ... no.

   Let me just work with the 2x2 matrix directly. */

/* For transverse mode k = k zhat:
   F_phi on delta_phi_x from delta_theta_y:
     eta * (curl delta_theta)_x = eta * d(delta_theta_y)/dz = eta * ik theta_y
     alpha2 * (curl curl delta_theta)_x = alpha2 * (-k^2 delta_theta_y)
       Wait: curl(curl F) for F = f_y yhat e^{ikz}:
       Step 1: curl F = (dF_z/dy - dF_y/dz) xhat + ... = (-ik f_y) xhat e^{ikz}
       Step 2: curl of (-ik f_y xhat e^{ikz}):
         = (d/dy(0) - d/dz(0)) xhat + (d/dz(-ikf_y e^{ikz}) - d/dx(0)) yhat + ...
         = (0) xhat + (-k^2 f_y e^{ikz}) yhat + ...

       So curl(curl(theta))_x = 0 for theta = theta_y yhat e^{ikz}.
       The curl^2 projects back onto the SAME component (y), not cross (x).

       This means: alpha2 curl(curl(theta)) in the phi equation
       does NOT create a cross-coupling with the same structure as curl(theta).

       It adds alpha2 k^2 to the DIAGONAL of the theta equation:
       curl(curl(phi)) in theta eq -> -k^2 delta_phi_x projected onto... hmm.

       Let me reconsider: the term is in the PHI equation:
       F_phi = ... + alpha2 curl(curl(theta))
       This is a VECTOR equation. The x-component:
       F_phi_x = ... + alpha2 [curl(curl(theta))]_x = 0 (as computed above)

       So curl(curl(theta)) does NOT contribute to the phi_x equation
       when theta is polarized in the y direction. It contributes to phi_y!
*/

print("IMPORTANT: curl(curl(theta_y yhat)) has NO x-component!")$
print("  curl(curl) maps y-polarization BACK to y, not to x.")$
print("  The cross-coupling eta*curl(theta) maps y to x (rotation by pi/2).")$
print("  But curl^2 maps y to y (rotation by pi, i.e., back to same axis).")$
print("")$
print("  Therefore alpha2*curl(curl(theta)) does NOT mix phi_x with theta_y.")$
print("  It adds a diagonal term to the theta equation:")$
print("  d^2 theta_y/dt^2 = (k^2 - alpha2 k^2) theta_y + ... = (1-alpha2)k^2 theta_y")$
print("")$

/* The theta dispersion becomes:
   omega^2 = (1 + alpha2) k^2  (effective speed modification)
   Wait — sign. curl(curl(theta)) in the theta equation:
   d^2 theta/dt^2 = laplacian(theta) + ... + alpha2 curl(curl(phi))

   But curl(curl(phi_x xhat)) projected onto theta_y yhat:
   curl(phi_x xhat e^{ikz})_y = d(phi_x e^{ikz})/dz = ik phi_x e^{ikz}
   curl of (... yhat ik phi_x e^{ikz}):
   [curl]_y = d/dz(...) = -k^2 phi_x -> no, this goes to different components.

   Let me just accept that curl^2 = -laplacian for div-free fields and
   work out the dispersion. */

print("For divergence-free fields: curl(curl(F)) = -laplacian(F)")$
print("  In theta equation: alpha2 curl(curl(phi)) = alpha2 k^2 phi (Fourier)")$
print("  In phi equation: alpha2 curl(curl(theta)) = alpha2 k^2 theta (Fourier)")$
print("")$
print("  BUT: these act on the SAME polarization component.")$
print("  The curl coupling eta*curl mixes ORTHOGONAL polarizations.")$
print("  The curl^2 coupling alpha2*curl^2 acts on PARALLEL polarizations.")$
print("")$
print("  Two separate 2x2 systems:")$
print("  Cross-polarization (phi_x, theta_y): coupled by eta*k")$
print("  Same-polarization (phi_x, theta_x): coupled by alpha2*k^2")$
print("")$

/* Same-polarization system: */
print("Same-polarization dispersion (phi_x, theta_x):")$
eq5_same: (w - k^2 - m^2) * (w - k^2) - alpha2^2 * k^4;
sol5_same: solve(eq5_same, w);
print("  (w - k^2 - m^2)(w - k^2) = alpha2^2 k^4")$
print("  Solutions: ", sol5_same)$
print("")$

/* At k=0: w(w - m^2) = 0 -> gaps at 0 and m^2. STILL GAPLESS. */
print("  At k=0: gaps at 0 and m^2. STILL GAPLESS lower branch.")$
print("")$

/* Cross-polarization remains: (w-k^2-m^2)(w-k^2) = eta^2 k^2, unchanged. */
print("Cross-polarization dispersion: UNCHANGED from base equations.")$
print("  (w-k^2-m^2)(w-k^2) = eta^2 k^2, same as before.")$
print("")$

/* What about the k^4 term creating a gap? */
/* At small k: omega^2 ~ k^2 - alpha2^2 k^4 / m^2 (from perturbation theory)
   This is STILL gapless — just modifies the dispersion at high k. */

/* Full dispersion: omega^2(k) for the lower branch of the same-pol system */
w5_lower: rhs(sol5_same[1]);
print("Lower branch (same-pol): w = ", w5_lower)$

/* Check: is this ever gapped? At k=0, w = 0. At large k, w ~ k^2. */
/* Taylor expand at small k: */
w5_taylor: taylor(w5_lower, k, 0, 4);
print("  Small-k expansion: w = ", w5_taylor)$
print("")$

print("  The lower branch starts at w=0 at k=0.")$
print("  No gap is created. The curl^2 term CANNOT open a gap.")$
print("")$

/* What about the specific case alpha2 curl^2 creating a DISPERSIVE gap?
   omega^2 = k^2 + alpha2 k^4 gives omega_min at k=0 still 0.
   There is no minimum at finite k. The dispersion is monotonically increasing. */

print("Pure dispersive case: omega^2 = k^2 + alpha2 k^4")$
print("  d(omega^2)/dk = 2k + 4 alpha2 k^3 > 0 for k > 0")$
print("  Monotonically increasing. NO gap at any k.")$
print("")$

print("--- MODIFICATION 5 VERDICT ---")$
print("  Term: alpha2 curl(curl(theta)) in phi equation (and vice versa)")$
print("  Dispersion: same-pol branch still gapless (w=0 at k=0)")$
print("  curl^2 adds k^4 correction, not a mass gap")$
print("  Total stability: NO")$
print("  Dealbreaker: higher-order derivatives modify high-k dispersion,")$
print("    but cannot open a gap at k=0. The gapless mode persists.")$
print("================================================================")$
print("")$


/* ================================================================
   MODIFICATION 6: Topological mass (Chern-Simons-like)
