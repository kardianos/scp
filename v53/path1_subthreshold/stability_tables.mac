        ) else if denom > -0.01 then
            printf(true, "    inf")
        else
            printf(true, "   NONE")
    ),
    printf(true, "~%")
)$

print("")$
print("NONE = C_R too small (beta^2 > 1 always). inf = marginal.")$
print("The critical C_R where stability becomes possible: C_R = pi*eta = ", float(%pi * eta_def))$
