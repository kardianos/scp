/* stability_tables.mac — Unified stability condition tables
 *
 * Stability condition:  alpha * S(xi) + beta^2 < 1
 *
 * where:
 *   alpha = |mu| / m^2
 *   beta  = pi * eta / (m * R_eff)
 *   xi    = kappa * P_eq^2
 *   S(xi) = |1 - 3*xi| / (1 + xi)^3
 *
 * Physical meaning:
 *   alpha * S(xi) = nonlinear restoring force / mass gap  (V'' contribution)
 *   beta^2        = curl coupling / mass gap               (torsion contribution)
 *   LHS < 1       => breathing frequency below mass gap => exponentially suppressed radiation
 *
 * KEY SUBTLETY: R_eff is the effective confinement radius for the curl
 * coupling, NOT the soliton's Gaussian core width. The curl coupling
 * is screened in the soliton core because theta_rms is small there
 * (theta_rms ~ 0.002-0.006 from simulations, while phi_max ~ 0.8).
 * The effective R should use the soliton's full profile extent (half-
 * width at half-max of the phi profile), not the virial core radius.
 *
 * From shape_analysis.mac: R ~ 0.4/m for the Gaussian core width.
 * The full soliton extent is typically 3-5x larger (tail region).
 * We calibrate R_eff from simulation data in Table 6.
 *
 * Run: maxima --batch=v53/path1_subthreshold/stability_tables.mac
 */

/* ================================================================
   SETUP AND CONVENTIONS
   ================================================================ */

/* Default parameters */
m_def: 1.5$
mu_def: -41.345$
kappa_def: 50$
eta_def: 0.5$
A_bg_def: 0.1$

/* The saturation function */
S(xi) := abs(1 - 3*xi) / (1 + xi)^3$

/* Stability LHS.
 * Two versions: with explicit R, and with R = C_R / m scaling.
 */
LHS_explicit(m_val, mu_val, kappa_val, eta_val, R_val, P_eq) := block(
    [alpha, beta, xi],
    alpha: abs(mu_val) / m_val^2,
    xi: kappa_val * P_eq^2,
    beta: %pi * eta_val / (m_val * R_val),
    alpha * S(xi) + beta^2
)$

/* With R = C_R / m, the beta term simplifies: */
LHS_scaled(m_val, mu_val, kappa_val, eta_val, C_R, P_eq) := block(
    [alpha, beta_sq, xi],
    alpha: abs(mu_val) / m_val^2,
    xi: kappa_val * P_eq^2,
    beta_sq: %pi^2 * eta_val^2 / C_R^2,  /* m cancels! */
    alpha * S(xi) + beta_sq
)$

/* ================================================================
   TABLE 1: S(xi) saturation function
   ================================================================ */

print("================================================================")$
print("TABLE 1: SATURATION FUNCTION S(xi) = |1 - 3*xi| / (1 + xi)^3")$
print("================================================================")$
print("")$
print("xi = kappa * P_eq^2, where P_eq = phi_0 * phi_1 * phi_2 (triple product)")$
print("S controls how strongly the nonlinear potential V(P) drives breathing.")$
print("")$

print("  xi          S(xi)        Region            Notes")$
print("  --------    ----------   --------          -----")$

xi_vals: [0, 0.001, 0.01, 0.05, 0.1, 0.2, 1/3, 0.5, 1.0, 2.0, 5.0, 10.0,
          13.1, 20.0, 50.0, 100.0]$

for xi_v in xi_vals do (
    s_val: float(S(xi_v)),
    region: if xi_v < 0.1 then "linear"
            elseif xi_v < 1 then "transition"
            else "saturated",
    note: "",
    if xi_v = 0 then note: "S=1 (no saturation)"
    elseif abs(xi_v - 0.001) < 1e-6 then note: "kappa=50, P~0.004"
    elseif abs(xi_v - 0.05) < 1e-4 then note: "kappa=50, P=A_bg^3=0.001 (bg)"
    elseif xi_v = 1/3 then note: "*** ZERO: V''=0 exactly ***"
    elseif abs(xi_v - 13.1) < 0.1 then note: "phi_max=0.8, P=0.51, kappa=50",
    printf(true, "  ~8,3f    ~12,8f   ~12a    ~a~%",
           float(xi_v), s_val, region, note)
)$

print("")$
print("Asymptotic behavior:")$
print("  xi -> 0:   S(xi) -> 1 - 6*xi + O(xi^2)  [linear limit]")$
print("  xi = 1/3:  S(xi) = 0                      [perfect cancellation]")$
print("  xi -> inf: S(xi) ~ 3/(xi^2)               [power-law decay]")$
print("")$
print("Physical regimes in the simulation:")$
print("  Background (A_bg=0.1): P ~ 0.001, xi ~ 5e-5   => S ~ 1.0 (radiating)")$
print("  Soliton tail:          P ~ 0.01,  xi ~ 0.005   => S ~ 0.97 (radiating)")$
print("  Soliton core:          P ~ 0.5,   xi ~ 12.5    => S ~ 0.02 (confined)")$
print("  The soliton is a localized region of suppressed S embedded in S~1 background.")$
print("")$

/* ================================================================
   TABLE 2: Stability map in (m, mu) space
   ================================================================ */

print("================================================================")$
print("TABLE 2: STABILITY MAP in (m, mu) SPACE")$
print("================================================================")$
print("")$
print("Condition: alpha * S(xi) + beta^2 < 1")$
print("With R = C_R / m: beta^2 = pi^2 * eta^2 / C_R^2 (m-independent!)")$
print("")$
print("This means the beta^2 term is a CONSTANT offset for given eta, C_R.")$
print("Only the alpha*S term depends on m and mu.")$
print("")$
print("Fixed: eta=0.5, kappa=50, P_eq=0.45 (soliton core)")$
print("S(xi=10.125) =", float(S(50 * 0.45^2)))$

P_eq_core: 0.45$
xi_core: kappa_def * P_eq_core^2$
S_core: float(S(xi_core))$

print("")$
print("--- Table 2a: alpha * S(xi) term only (no torsion) ---")$
print("Values show alpha*S = |mu|*S(xi)/m^2 for each (m, mu).")$
print("This is the contribution from the nonlinear potential alone.")$
print("")$

printf(true, "~7a |", "m\\mu")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7d", mu_v)
)$
printf(true, "~%")$

printf(true, "~7a-|", "------")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7a", "------")
)$
printf(true, "~%")$

for m_v: 1.0 step 0.25 thru 5.0 do (
    printf(true, "~5,2f   |", m_v),
    for mu_v: -5 step -5 thru -60 do (
        alpha_v: abs(mu_v) / m_v^2,
        aS: float(alpha_v * S_core),
        if aS < 0.5 then
            printf(true, " ~5,3f", aS)
        elseif aS < 1.0 then
            printf(true, " ~4,2f*", aS)
        else
            printf(true, " ~4,1fX", aS)
    ),
    printf(true, "~%")
)$

print("")$
print("Key: values < 0.5 mean the potential term alone is well below threshold.")$
print("The alpha*S term is ALWAYS small (< 1.3) because S(xi)=0.021 suppresses it.")$
print("Even the worst case (m=1.0, mu=-60) has alpha*S = 1.28.")$
print("Saturation is highly effective at suppressing the potential contribution.")$
print("")$

/* Now show the full condition with various C_R values */
print("--- Table 2b: Full LHS for C_R = 1.0 (torsion mild) ---")$
print("beta^2 = pi^2 * 0.25 / 1.0 = ", float(%pi^2 * eta_def^2 / 1.0^2))$
print("")$

C_R_2b: 1.0$
beta2_2b: float(%pi^2 * eta_def^2 / C_R_2b^2)$

printf(true, "~7a |", "m\\mu")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7d", mu_v)
)$
printf(true, "~%")$

printf(true, "~7a-|", "------")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7a", "------")
)$
printf(true, "~%")$

for m_v: 1.0 step 0.25 thru 5.0 do (
    printf(true, "~5,2f   |", m_v),
    for mu_v: -5 step -5 thru -60 do (
        alpha_v: abs(mu_v) / m_v^2,
        lhs_v: float(alpha_v * S_core + beta2_2b),
        if lhs_v < 0.8 then
            printf(true, " ~5,2f", lhs_v)
        elseif lhs_v < 1.0 then
            printf(true, " ~4,2f*", lhs_v)
        else
            printf(true, " ~4,1fX", lhs_v)
    ),
    printf(true, "~%")
)$

print("")$
print("With C_R=1.0: beta^2=2.47, so all entries have LHS > 2.47.")$
print("Only the alpha*S term varies; it is always small (0.1-1.3).")$
print("Everything is unstable at C_R=1.0.")$
print("")$

print("--- Table 2c: Full LHS for C_R = 2.5 (torsion well-screened) ---")$
C_R_2c: 2.5$
beta2_2c: float(%pi^2 * eta_def^2 / C_R_2c^2)$
print("beta^2 = pi^2 * 0.25 / 6.25 = ", beta2_2c)$
print("")$

printf(true, "~7a |", "m\\mu")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7d", mu_v)
)$
printf(true, "~%")$

printf(true, "~7a-|", "------")$
for mu_v: -5 step -5 thru -60 do (
    printf(true, "~7a", "------")
)$
printf(true, "~%")$

for m_v: 1.0 step 0.25 thru 5.0 do (
