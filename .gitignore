# Ignore files and folders without a dot
[^.]*
# Negate for files with an extension
!*.*
# Negate for Makefiles (caught by [^.]* but not executables)
!Makefile
# Ensure directories containing files with extensions are not ignored
!*/
*.wasm
*.scpv
*.bin
*.dat
*.o
*.sqlite
build/
target/
radial_solver
*.tsv
*.txt
*.sfa
*.ppm
*.png
# Generated images and data
*.ppm
*.png
*.webp
*.sfa
*.bin
*.o
lean/.lake
# Lean build artifacts anywhere in the tree
.lake/
*.olean
*.olean.trace
*.olean.lock

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo

# Reference papers (kept local only)
ref/

# LaTeX/pandoc build artifacts (keep .tex sources, ignore generated)
*.pdf
*.aux
*.bbl
*.blg
*.toc
*.synctex
*.synctex.gz
*_build.log
pandoc_build.log

# Ganja scan output dumps (regeneratable from python scripts)
ganja_exports_round*/

key.txt
.claude/worktrees/*
*.npz
sfa/runner/scp-runner
sfa/runner/runner
bin/
